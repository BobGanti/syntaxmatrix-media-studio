SINGAPORE_API_KEY=your_alibaba_api_key_here
SINGAPORE_WORKSPACE_ID=your_workspace_id_here

# Optional: set to 1 to test uploads without calling Alibaba.
# ALIBABA_MEDIA_DRY_RUN=1

# --- Billing provider placeholders ---
# dev is used locally. Later choose stripe or paddle.
BILLING_PROVIDER=dev

# Never enable unverified provider webhooks in production.
BILLING_ACCEPT_UNVERIFIED_WEBHOOKS=false

# Real provider webhook secrets, filled later.
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
PADDLE_WEBHOOK_SECRET=replace_with_paddle_webhook_secret

# Public app URL used later by checkout redirects.
APP_PUBLIC_URL=http://127.0.0.1:5055

# --- Development auth boundary ---
# Local development only. Replace with real login/session/JWT auth before production.
DEV_AUTH_ENABLED=true

# admin can open admin/finance pages and manage all workspaces.
# client can only use the workspace specified below.
DEV_AUTH_ROLE=admin
DEV_AUTH_USER_ID=dev_admin
DEV_AUTH_WORKSPACE_ID=mock_user_001

# --- Customer/workspace development identities ---
# Seeded users:
#   dev_admin      -> owner/admin of all demo workspaces
#   dev_client_001 -> member of mock_user_001
#   dev_client_002 -> member of mock_user_002
#
# Seeded workspaces:
#   mock_user_001 -> Client A / Workspace 001
#   mock_user_002 -> Client B / Workspace 002

# --- Stripe Checkout ---
# Install dependency:
#   pip install stripe
#
# Use your Stripe test secret key locally. Never commit real secrets.
STRIPE_SECRET_KEY=replace_with_stripe_test_secret_key

# Used for Checkout success/cancel redirects.
APP_PUBLIC_URL=http://127.0.0.1:5055

# --- Stripe Webhooks ---
# Local test:
#   stripe listen --forward-to localhost:5055/api/billing/webhook/stripe
#
# Copy the whsec_... value printed by Stripe CLI into your local .env:
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_signing_secret
